# ── Gateway ────────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
CONFIG_PATH=config/config.yaml
LOG_LEVEL=INFO

# ── Redis ──────────────────────────────────────────────────
# In docker-compose this is set to redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Provider credentials ───────────────────────────────────
# Leave blank to run with the mock provider only (zero cost, no keys needed).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Ollama runs locally; override if not on default host.
OLLAMA_BASE_URL=http://localhost:11434

# ── Admin API ──────────────────────────────────────────────
# Bearer token required to call /admin/* endpoints.
# CHANGE THIS in any real deployment — the default is for local demo only.
ADMIN_API_KEY=changeme-admin-key
