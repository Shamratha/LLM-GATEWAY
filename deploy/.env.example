# Production secrets for the VM deploy. Copy to .env on the VM and fill in:
#   cp deploy/.env.example .env  &&  nano .env
# NEVER commit the real .env (it's gitignored).

# Your DuckDNS domain, pointed at the VM's public IP (no https://, no path).
DOMAIN=yourname.duckdns.org

# Strong random string — the bearer token for /admin/* endpoints.
# Generate one:  openssl rand -hex 32
ADMIN_API_KEY=change-me-to-a-long-random-string

# Grafana admin password (username is 'admin').
GRAFANA_ADMIN_PASSWORD=change-me

# Optional real provider keys. Leave blank to run on the zero-cost mock provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
